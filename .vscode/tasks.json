{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C 실행 (한번에)",
            "type": "shell",
            // 1. 컴파일(gcc) -> 2. 실행(./out) -> 3. 실행파일 삭제(rm out)
            "command": "gcc ${file} -o ${fileDirname}/out.temp && ${fileDirname}/out.temp && rm ${fileDirname}/out.temp",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "focus": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}
